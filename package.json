{
  "name": "tasktracker",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:build": "vite build --config electron/vite.config.ts",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && npm run electron:build && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "dist:mac": "npm run electron:build && electron-builder --mac --publish always",
    "dist:win": "npm run electron:build && electron-builder --win --publish always",
    "dist:all": "npm run electron:build && electron-builder --mac --win --publish always"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.90",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@xyflow/react": "^12.10.2",
    "convex": "^1.32.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "openai": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  }
}
